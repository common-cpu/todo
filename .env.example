# Asana
ASANA_ACCESS_TOKEN=your_asana_personal_access_token

# 対象プロジェクト: name と gid のペアをJSON配列で指定
ASANA_PROJECTS=[{"name":"Provia","gid":"PROVIA_PROJECT_GID"},{"name":"DataArt","gid":"DATAART_PROJECT_GID"},{"name":"BlueVoyant","gid":"BLUEVOYANT_PROJECT_GID"},{"name":"Blueship","gid":"BLUESHIP_PROJECT_GID"},{"name":"ZIPAIR Tokyo","gid":"ZIPAIR_PROJECT_GID"}]

# Google Chat
GOOGLE_CHAT_SPACE_ID=spaces/your_space_id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Member Mappings (Asana User → Google Chat User)
# Google Chat User ID は Google Admin SDK / People API で取得
MEMBER_MAPPINGS=[{"asanaUserId":"1213783311748281","asanaUserName":"Ai Yamano","googleChatUserId":"users/GOOGLE_CHAT_USER_ID_1"},{"asanaUserId":"1209901408642066","asanaUserName":"Chisa Watanabe","googleChatUserId":"users/GOOGLE_CHAT_USER_ID_2"},{"asanaUserId":"1209901409478310","asanaUserName":"Yoritaka Mochinaga","googleChatUserId":"users/GOOGLE_CHAT_USER_ID_3"}]
