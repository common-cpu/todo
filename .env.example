# Asana
ASANA_ACCESS_TOKEN=your_asana_personal_access_token

# 対象プロジェクト: name と gid のペアをJSON配列で指定
ASANA_PROJECTS=[{"name":"Provia","gid":"1214016121056319"},{"name":"Blueship","gid":"1214016121056325"},{"name":"BlueVoyant","gid":"1214016121056331"},{"name":"DataArt","gid":"1214016121056337"},{"name":"ZIPAIR Tokyo","gid":"1214023936100425"}]

# Google Chat
GOOGLE_CHAT_SPACE_ID=spaces/your_space_id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Member Mappings (Asana User → Google Chat User)
# Google Chat User ID は Google Admin SDK / People API で取得
MEMBER_MAPPINGS=[{"asanaUserId":"1213783311748281","asanaUserName":"Ai Yamano","googleChatUserId":"users/GOOGLE_CHAT_USER_ID_AI_YAMANO"},{"asanaUserId":"1209901408642066","asanaUserName":"Chisa Watanabe","googleChatUserId":"users/GOOGLE_CHAT_USER_ID_CHISA_WATANABE"},{"asanaUserId":"1209901409478310","asanaUserName":"Yoritaka Mochinaga","googleChatUserId":"users/GOOGLE_CHAT_USER_ID_YORITAKA_MOCHINAGA"}]
