# Asana
ASANA_ACCESS_TOKEN=your_asana_personal_access_token

# 対象プロジェクト: name と gid のペアをJSON配列で指定
ASANA_PROJECTS=[{"name":"Provia","gid":"1214016121056319"},{"name":"Blueship","gid":"1214016121056325"},{"name":"BlueVoyant","gid":"1214016121056331"},{"name":"DataArt","gid":"1214016121056337"},{"name":"ZIPAIR Tokyo","gid":"1214023936100425"}]

# Google Chat Webhook URL
# Google Chat スペース > スペース名 > アプリと統合 > Webhook で取得
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/YOUR_SPACE_ID/messages?key=YOUR_KEY&token=YOUR_TOKEN

# Member Mappings (Asana User → Google Chat User) [任意]
# Google Chat User ID は Google Admin SDK / People API で取得
# 設定しない場合はメンションなしで担当者名のみ表示
MEMBER_MAPPINGS=[{"asanaUserId":"1213783311748281","asanaUserName":"Ai Yamano","googleChatUserId":"users/GOOGLE_CHAT_USER_ID"},{"asanaUserId":"1209901408642066","asanaUserName":"Chisa Watanabe","googleChatUserId":"users/GOOGLE_CHAT_USER_ID"},{"asanaUserId":"1209901409478310","asanaUserName":"Yoritaka Mochinaga","googleChatUserId":"users/GOOGLE_CHAT_USER_ID"}]
